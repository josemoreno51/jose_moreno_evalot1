<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background_gray">

    <!-- Header elegante -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="4dp"
        android:backgroundTint="@color/white">

        <!-- Título -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Noticias PPS"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary_blue_dark" />

        <!-- Botón Agregar Noticia -->

        <!-- Botón Cerrar Sesión -->

    </LinearLayout>

    <!-- Mensaje cuando no hay noticias -->
    <Button
        android:id="@+id/btnAgregarNoticia"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="12dp"
        android:backgroundTint="@color/accent_green"
        android:elevation="2dp"
        android:stateListAnimator="@null"
        android:text="+"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No hay noticias disponibles\n\nHaz clic en '+' para crear la primera"
        android:textSize="18sp"
        android:textColor="@color/text_secondary"
        android:visibility="visible" />

    <!-- Lista de Noticias -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewNoticias"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="80dp"
        android:layout_height="48dp"
        android:backgroundTint="@color/error_red"
        android:elevation="2dp"
        android:stateListAnimator="@null"
        android:text="Salir"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>