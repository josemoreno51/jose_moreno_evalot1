<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:fillViewport="true"
    android:gravity="center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="center_vertical">

        <!-- ESPACIO SUPERIOR MÁS GRANDE -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="80dp" />

        <!-- Título BAJADO MÁS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="60dp"
            android:text="Agregar Noticia"
            android:textSize="34sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/primary_blue_dark" />

        <!-- Campos -->
        <EditText
            android:id="@+id/etTitulo"
            android:layout_width="320dp"
            android:layout_height="55dp"
            android:hint="Título"
            android:gravity="center"
            android:layout_marginBottom="30dp"
            android:textSize="17sp" />

        <EditText
            android:id="@+id/etResumen"
            android:layout_width="320dp"
            android:layout_height="55dp"
            android:hint="Resumen"
            android:gravity="center"
            android:layout_marginBottom="30dp"
            android:textSize="17sp" />

        <EditText
            android:id="@+id/etContenido"
            android:layout_width="320dp"
            android:layout_height="200dp"
            android:hint="Contenido"
            android:gravity="top|center_horizontal"
            android:layout_marginBottom="30dp"
            android:textSize="17sp" />

        <EditText
            android:id="@+id/etAutor"
            android:layout_width="320dp"
            android:layout_height="55dp"
            android:hint="Autor"
            android:gravity="center"
            android:layout_marginBottom="50dp"
            android:textSize="17sp" />

        <!-- Botones -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="40dp">

            <Button
                android:id="@+id/btnCancelar"
                android:layout_width="150dp"
                android:layout_height="60dp"
                android:text="Cancelar"
                android:layout_marginEnd="20dp"
                android:backgroundTint="@color/medium_gray"
                android:textColor="@color/white"
                android:textSize="17sp" />

            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="150dp"
                android:layout_height="60dp"
                android:text="Guardar"
                android:layout_marginStart="20dp"
                android:backgroundTint="@color/accent_green"
                android:textColor="@color/white"
                android:textSize="17sp" />

        </LinearLayout>

        <!-- Espacio inferior -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>
</ScrollView>