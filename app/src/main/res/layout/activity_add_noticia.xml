<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:fillViewport="true"
    android:gravity="center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="center_vertical">

        <!-- BOTÓN DE SALIR EN LA ESQUINA SUPERIOR DERECHA -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp">

            <Button
                android:id="@+id/btnSalir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="X"
                android:textSize="20sp"
                android:textStyle="bold"
                android:minWidth="50dp"
                android:minHeight="50dp"
                android:background="@drawable/btn_salir_redondo"
                android:textColor="@color/white" />

        </RelativeLayout>

        <!-- ESPACIO SUPERIOR -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:text="Agregar Noticia"
            android:textSize="34sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/primary_blue_dark" />

        <!-- Campos -->
        <EditText
            android:id="@+id/etTitulo"
            android:layout_width="320dp"
            android:layout_height="55dp"
            android:hint="Título"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            android:textSize="17sp" />

        <EditText
            android:id="@+id/etResumen"
            android:layout_width="320dp"
            android:layout_height="55dp"
            android:hint="Resumen"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            android:textSize="17sp" />

        <!-- SECCIÓN PARA LA FOTO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Imagen de la Noticia"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"
            android:textColor="@color/primary_blue_dark" />

        <!-- Vista previa de la imagen -->
        <ImageView
            android:id="@+id/ivPreview"
            android:layout_width="200dp"
            android:layout_height="150dp"
            android:layout_marginBottom="15dp"
            android:background="@color/light_gray"
            android:scaleType="centerCrop"
            android:contentDescription="Vista previa de la imagen" />

        <!-- Botón para seleccionar foto -->
        <Button
            android:id="@+id/btnSeleccionarFoto"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:layout_marginBottom="25dp"
            android:text="📷 Seleccionar Foto"
            android:textSize="16sp"
            android:backgroundTint="@color/primary_blue"
            android:textColor="@color/white" />

        <!-- O mostrar enlace para URL de imagen -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="O ingresa URL de la imagen:"
            android:textSize="14sp"
            android:layout_marginBottom="10dp"
            android:textColor="@color/medium_gray" />

        <EditText
            android:id="@+id/etUrlImagen"
            android:layout_width="320dp"
            android:layout_height="55dp"
            android:hint="https://ejemplo.com/imagen.jpg"
            android:gravity="center"
            android:layout_marginBottom="25dp"
            android:textSize="15sp"
            android:inputType="textUri" />

        <!-- Contenido -->
        <EditText
            android:id="@+id/etContenido"
            android:layout_width="320dp"
            android:layout_height="200dp"
            android:hint="Contenido"
            android:gravity="top|center_horizontal"
            android:layout_marginBottom="20dp"
            android:textSize="17sp" />

        <EditText
            android:id="@+id/etAutor"
            android:layout_width="320dp"
            android:layout_height="55dp"
            android:hint="Autor"
            android:gravity="center"
            android:layout_marginBottom="40dp"
            android:textSize="17sp" />

        <!-- Botones -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="40dp">

            <Button
                android:id="@+id/btnCancelar"
                android:layout_width="150dp"
                android:layout_height="60dp"
                android:text="Cancelar"
                android:layout_marginEnd="20dp"
                android:backgroundTint="@color/medium_gray"
                android:textColor="@color/white"
                android:textSize="17sp" />

            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="150dp"
                android:layout_height="60dp"
                android:text="Guardar"
                android:layout_marginStart="20dp"
                android:backgroundTint="@color/accent_green"
                android:textColor="@color/white"
                android:textSize="17sp" />

        </LinearLayout>

        <!-- Espacio inferior -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>
</ScrollView>